---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

{% if page.tab and page.tab_file %}
  <div class="container-fluid mt-5">
    <div class="mb-3">
      <a
        class="btn btn-sm tab-download-btn"
        href="{{ page.tab_file | prepend: '/assets/tabs/' | relative_url }}"
        download="{{ page.tab_file | split: '/' | last }}"
      >
        <i class="fas fa-download"></i> Download .gp file
      </a>
    </div>
    <div
      id="alphaTabWrapper"
      data-tab-file="{{ page.tab_file | prepend: '/assets/tabs/' | relative_url }}"
      data-soundfont="{{ '/assets/soundfonts/font.sf2' | relative_url }}"
    >
      {% include tab.liquid %}
    </div>
  </div>
{% endif %}

  <article>
    {{ content }}
  </article>



  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
